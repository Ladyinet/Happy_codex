###########################################
# BINGX API CONFIG
###########################################

# BingX API key
BINGX_API_KEY=bVphrcHLFJ5o4kbK3c

# BingX API secret
BINGX_API_SECRET=0l1JDxhGTNq84GV5N8Qi3cAubOlxLAQeiaYu

# Use BingX testnet when supported
BINGX_TESTNET=false

###########################################
# BOT MODE
###########################################

# Allowed values: backtest, dry_run, live
MODE=dry_run

###########################################
# MARKET CONFIG
###########################################

# Trading symbol
SYMBOL=BTC-USDT

# Strategy timeframe
TIMEFRAME=1m

# Candles to preload on startup
STARTUP_CANDLES_BACKFILL=300

###########################################
# STRATEGY PARAMETERS
###########################################

# Start order fixed coin size
FIRST_SELL_QTY_COIN=0.09

# Use percent of equity for base order sizing
USE_EQUITY_PCT_BASE=false

# Base order percent of equity
BASE_ORDER_PCT_EQ=0

# Fixed equity used for sizing
EQUITY_FOR_SIZING_USDT=100

# Full TP percent
TP_PERCENT=1.1

# Trailing callback percent
CALLBACK_PERCENT=0.2

# Sub-cover TP percent
SUB_SELL_TP_PERCENT=1.3

# Maximum DCA levels
MARGIN_CALL_LIMIT=244

# Block DCA after TP touch until confirmation
BLOCK_DCA_ON_TP_TOUCH=true

# Require close below full TP level
REQUIRE_CLOSE_BELOW_FULL_TP=true

# Touch mode: wick, body, close
TOUCH_MODE=wick

# Sub-cover confirm mode: off, breakeven, subcover_tp
SUBCOVER_CONFIRM_MODE=subcover_tp

###########################################
# EVEN BAR FILTER
###########################################

# Enable even-bar filter
ENABLE_EVEN_BAR_FILTER=true

# Anchor mode: utc_day_start, live_start, fixed_timestamp
EVEN_BAR_ANCHOR_MODE=utc_day_start

# Optional fixed anchor timestamp in ISO format
EVEN_BAR_FIXED_TIMESTAMP=

###########################################
# RISK LIMITS
###########################################

# Maximum orders per rolling 3-minute window
MAX_ORDERS_PER_3MIN=14

# Maximum DCA fills per bar
MAX_DCA_PER_BAR=6

# Maximum sub-covers per bar
MAX_SUBCOVER_PER_BAR=10

###########################################
# SYNC / RECOVERY
###########################################

# Live start policy: reset, restore, sync_only
LIVE_START_POLICY=reset

# Policy on state desynchronization: safe_stop, rebuild_from_exchange, manual_confirm
DESYNC_POLICY=safe_stop

# Invalid order policy: adjust, skip, safe_stop
INVALID_ORDER_POLICY=adjust

###########################################
# API ERROR HANDLING
###########################################

# Maximum API retries
API_MAX_RETRIES=3

# Base backoff in seconds
API_BACKOFF_BASE_SECONDS=1

# Backoff mode: exponential
API_BACKOFF_MODE=exponential

###########################################
# TELEGRAM CONFIG
###########################################

# Telegram bot token
TELEGRAM_BOT_TOKEN=8386539856:AAHCWCs7eKhxBN6ieq2S9M65jxb4E4yIaGs

# Enable Telegram notifications
TELEGRAM_ENABLED=true

# SQLite database file
SQLITE_DB_PATH=bot_state.db

# Telegram throttling
TELEGRAM_MAX_MESSAGES_PER_SECOND=10

###########################################
# LOGGING
###########################################

# Log level
LOG_LEVEL=INFO

# Log file path
LOG_FILE=bot.log
